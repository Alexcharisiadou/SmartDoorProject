#include <SPI.h>
#include <MFRC522.h>
#include <Keypad.h>
#include <ESP32Servo.h>
#include <LiquidCrystal_I2C.h>

// ════════════════════════════════════════════════════════
//   ΕΞΥΠΝΗ ΠΥΛΗ ΕΙΣΟΔΟΥ ΚΤΙΡΙΟΥ
//   Μέθοδοι πρόσβασης: RFID κάρτα + PIN μέσω Keypad
//   Hardware: ESP32, MFRC522, Keypad 4x4, Servo,
//             HC-SR04 Ultrasonic, LCD 16x2 I2C
// ════════════════════════════════════════════════════════

// ─── RFID RC522 ──────────────────────────────────────────
// Το RFID module χρησιμοποιεί SPI επικοινωνία με τον ESP32
// SS_PIN  : Slave Select - ενεργοποιεί το module
// RST_PIN : Reset - αρχικοποιεί το module όταν χρειαστεί
#define SS_PIN    5
#define RST_PIN   27
MFRC522 rfid(SS_PIN, RST_PIN);  // Δημιουργία αντικειμένου RFID

// ─── SERVO MOTOR ─────────────────────────────────────────
// Ο servo κινεί φυσικά την πύλη
// 0°  = κλειστή πύλη
// 90° = ανοιχτή πύλη
#define SERVO_PIN 15
Servo gateServo;

// ─── ULTRASONIC HC-SR04 ───────────────────────────────────
// Ο αισθητήρας μετρά απόσταση για να αποφύγει
// να κλείσει η πύλη πάνω σε άνθρωπο ή εμπόδιο
// TRIG: στέλνει υπερηχητικό παλμό
// ECHO: λαμβάνει την ανάκλαση και μετράει χρόνο
#define TRIG_PIN  4
#define ECHO_PIN  2

// ─── LCD 16x2 με I2C ─────────────────────────────────────
// Η οθόνη εμφανίζει μηνύματα κατάστασης στον χρήστη
// Διεύθυνση I2C: 0x27 (συνηθισμένη για LCD με I2C adapter)
// Αν δεν δουλεύει δοκίμασε 0x3F
LiquidCrystal_I2C lcd(0x27, 16, 2);

// ─── KEYPAD 4×4 ──────────────────────────────────────────
// Ο χρήστης πληκτρολογεί PIN για να ανοίξει την πύλη
// Διάταξη πλήκτρων όπως εμφανίζεται στο keypad
const byte ROWS = 4;  // 4 γραμμές
const byte COLS = 4;  // 4 στήλες
char keys[ROWS][COLS] = {
  {'1','2','3','A'},
  {'4','5','6','B'},
  {'7','8','9','C'},
  {'*','0','#','D'}
};
// rowPins: GPIO pins που συνδέονται στις γραμμές του keypad (R1-R4)
// colPins: GPIO pins που συνδέονται στις στήλες του keypad (C1-C4)
byte rowPins[ROWS] = {13, 12, 14, 26};
byte colPins[COLS] = {25, 33, 32, 35};
Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

// ─── ΣΤΑΘΕΡΕΣ ΣΥΣΤΗΜΑΤΟΣ ─────────────────────────────────
// CORRECT_PIN    : το μυστικό PIN που δίνει πρόσβαση
// AUTHORIZED_UID : το UID της εξουσιοδοτημένης RFID κάρτας
//                  (βρες το από το Serial Monitor όταν σκανάρεις την κάρτα)
const String CORRECT_PIN    = "1234";
const String AUTHORIZED_UID = "A1B2C3D4";

// ─── ΜΕΤΑΒΛΗΤΕΣ ΚΑΤΆΣΤΑΣΗΣ ───────────────────────────────
String enteredPin = "";         // Αποθηκεύει τα ψηφία που πληκτρολογεί ο χρήστης
bool gateOpen = false;          // true = πύλη ανοιχτή, false = κλειστή
unsigned long gateOpenTime = 0; // Χρονική στιγμή που άνοιξε η πύλη (ms)

// Χρόνος που μένει ανοιχτή η πύλη πριν κλείσει αυτόματα (5 δευτερόλεπτα)
const unsigned long GATE_OPEN_DURATION = 5000;

// ════════════════════════════════════════════════════════
//   SETUP - Εκτελείται μία φορά κατά την εκκίνηση
// ════════════════════════════════════════════════════════
void setup() {
  Serial.begin(115200); // Ενεργοποίηση Serial για debugging

  // Αρχικοποίηση SPI και RFID module
  SPI.begin();
  rfid.PCD_Init();
  Serial.println("RFID Reader έτοιμο.");

  // Σύνδεση servo και αρχική θέση (κλειστή πύλη)
  gateServo.attach(SERVO_PIN);
  gateServo.write(0);
  Serial.println("Servo αρχικοποιήθηκε - Πύλη ΚΛΕΙΣΤΗ.");

  // Ορισμός pins ultrasonic
  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);
  Serial.println("Ultrasonic sensor έτοιμο.");

  // Αρχικοποίηση LCD και εμφάνιση μηνύματος εκκίνησης
  lcd.init();
  lcd.backlight();
  lcd.setCursor(0, 0);
  lcd.print("  Smart Gate  ");
  lcd.setCursor(0, 1);
  lcd.print(" Initializing ");
  delay(2000);

  showIdle(); // Εμφάνιση αρχικής οθόνης αναμονής
}

// ════════════════════════════════════════════════════════
//   LOOP - Επαναλαμβάνεται συνεχώς
// ════════════════════════════════════════════════════════
void loop() {

  // ── Βήμα 1: Έλεγχος αυτόματου κλεισίματος πύλης ──────
  // Αν έχει περάσει ο χρόνος GATE_OPEN_DURATION από το άνοιγμα
  if (gateOpen && (millis() - gateOpenTime >= GATE_OPEN_DURATION)) {

    if (getDistance() > 20) {
      // Δεν υπάρχει εμπόδιο κοντά → κλείσε την πύλη κανονικά
      closeGate();
    } else {
      // Εντοπίστηκε εμπόδιο → περίμενε, μην κλείσεις
      lcd.clear();
      lcd.setCursor(0, 0);
      lcd.print("  Εμπόδιο!  ");
      lcd.setCursor(0, 1);
      lcd.print("  Αναμονή...  ");
      gateOpenTime = millis(); // Επαναφορά του χρονομέτρου
      Serial.println("⚠️ Εμπόδιο εντοπίστηκε - αναβολή κλεισίματος.");
    }
  }

  // ── Βήμα 2: Έλεγχος για νέα RFID κάρτα ───────────────
  checkRFID();

  // ── Βήμα 3: Έλεγχος για πλήκτρα στο Keypad ───────────
  checkKeypad();
}

// ════════════════════════════════════════════════════════
//   ΣΥΝΑΡΤΗΣΕΙΣ
// ════════════════════════════════════════════════════════

// ── Ανάγνωση και έλεγχος RFID κάρτας ────────────────────
// Διαβάζει το UID της κάρτας και το συγκρίνει με το εξουσιοδοτημένο
void checkRFID() {
  // Αν δεν υπάρχει νέα κάρτα κοντά, επέστρεψε
  if (!rfid.PICC_IsNewCardPresent() || !rfid.PICC_ReadCardSerial()) return;

  // Μετατροπή UID σε αναγνώσιμη μορφή hex string (π.χ. "A1B2C3D4")
  String uid = "";
  for (byte i = 0; i < rfid.uid.size; i++) {
    if (rfid.uid.uidByte[i] < 0x10) uid += "0"; // Προσθήκη μηδενικού αν χρειάζεται
    uid += String(rfid.uid.uidByte[i], HEX);
  }
  uid.toUpperCase(); // Κεφαλαία για ομοιομορφία

  Serial.println("📡 RFID UID που διαβάστηκε: " + uid);

  // Σύγκριση με εξουσιοδοτημένο UID
  if (uid == AUTHORIZED_UID) {
    grantAccess("RFID OK");
  } else {
    denyAccess("Αγνωστη καρτα");
  }

  // Σταμάτημα επικοινωνίας με κάρτα για αποφυγή επανάληψης
  rfid.PICC_HaltA();
  rfid.PCD_StopCrypto1();
}

// ── Ανάγνωση Keypad και έλεγχος PIN ──────────────────────
// # = επιβεβαίωση PIN
// * = διαγραφή / επαναφορά
// 0-9 = προσθήκη ψηφίου
void checkKeypad() {
  char key = keypad.getKey();
  if (!key) return; // Κανένα πλήκτρο δεν πατήθηκε

  if (key == '#') {
    // Ο χρήστης επιβεβαιώνει το PIN
    Serial.println("🔑 PIN που εισήχθη: " + enteredPin);
    if (enteredPin == CORRECT_PIN) {
      grantAccess("PIN OK");
    } else {
      denyAccess("Lathos PIN");
    }
    enteredPin = ""; // Καθαρισμός PIN μετά τον έλεγχο

  } else if (key == '*') {
    // Ο χρήστης ακυρώνει και ξεκινά από την αρχή
    enteredPin = "";
    Serial.println("🔄 PIN διαγράφηκε.");
    showIdle();

  } else {
    // Προσθήκη ψηφίου στο PIN
    enteredPin += key;

    // Εμφάνιση αστερίσκων στην οθόνη για λόγους ασφάλειας
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Eisagogi PIN:");
    lcd.setCursor(0, 1);
    String stars = "";
    for (int i = 0; i < (int)enteredPin.length(); i++) stars += "*";
    lcd.print(stars);
  }
}

// ── Επιτυχής πρόσβαση ────────────────────────────────────
// Καλείται όταν το PIN ή το RFID είναι σωστό
void grantAccess(String method) {
  Serial.println("✅ Προσβαση επιτραπηκε - " + method);
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print(" KALOS IRTHES  ");
  lcd.setCursor(0, 1);
  lcd.print("  " + method + "  ");
  openGate();
}

// ── Απόρριψη πρόσβασης ───────────────────────────────────
// Καλείται όταν το PIN ή το RFID είναι λάθος
void denyAccess(String reason) {
  Serial.println("❌ Προσβαση απορριφθηκε - " + reason);
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print(" ACCESS DENIED ");
  lcd.setCursor(0, 1);
  lcd.print(" " + reason + " ");
  delay(2000);  // Εμφάνιση μηνύματος για 2 δευτερόλεπτα
  showIdle();
}

// ── Άνοιγμα πύλης ────────────────────────────────────────
// Κινεί τον servo στα 90° και ξεκινά το χρονόμετρο αυτόματου κλεισίματος
void openGate() {
  gateServo.write(90);        // 90° = ανοιχτή θέση
  gateOpen = true;
  gateOpenTime = millis();    // Καταγραφή χρόνου ανοίγματος
  Serial.println("🚪 Πυλη ΑΝΟΙΧΤΗ - Αυτοματο κλεισιμο σε 5 δευτερολεπτα.");
}

// ── Κλείσιμο πύλης ───────────────────────────────────────
// Επιστρέφει τον servo στα 0° (κλειστή θέση)
void closeGate() {
  gateServo.write(0);   // 0° = κλειστή θέση
  gateOpen = false;
  Serial.println("🚪 Πυλη ΚΛΕΙΣΤΗ.");
  showIdle();
}

// ── Μέτρηση απόστασης με Ultrasonic ──────────────────────
// Στέλνει παλμό και μετρά πόσο χρόνο παίρνει να επιστρέψει
// Επιστρέφει απόσταση σε εκατοστά (cm)
long getDistance() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH);   // Έναρξη παλμού 10μs
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);    // Τέλος παλμού

  // pulseIn: μετρά χρόνο (μs) που το ECHO παραμένει HIGH
  // timeout 30000μs = 30ms ≈ μέγιστη απόσταση ~5 μέτρα
  long duration = pulseIn(ECHO_PIN, HIGH, 30000);

  // Τύπος: απόσταση = (χρόνος × ταχύτητα_ήχου) / 2
  // Ταχύτητα ήχου ≈ 0.034 cm/μs, διαιρούμε με 2 (πήγαινε + γύρισε)
  return duration * 0.034 / 2;
}

// ── Οθόνη αναμονής ───────────────────────────────────────
// Εμφανίζεται όταν το σύστημα είναι έτοιμο για είσοδο
void showIdle() {
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Scan RFID or");
  lcd.setCursor(0, 1);
  lcd.print("PIN + # ");
}
