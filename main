#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include <ESP32Servo.h>
#include <Keypad.h>

// ── Blynk ─────────────────────────────────────────────
#define BLYNK_TEMPLATE_ID   "TMPLxxxxxx"
#define BLYNK_TEMPLATE_NAME "Smart Door"
#define BLYNK_AUTH_TOKEN    "xxxxxxxxxxxx"
#include <WiFi.h>
#include <BlynkSimpleEsp32.h>
char ssid[] = "το_WiFi_σου";
char pass[] = "ο_κωδικός_σου";

// ── LCD ───────────────────────────────────────────────
LiquidCrystal_I2C lcd(0x27, 16, 2);

// ── Servo ─────────────────────────────────────────────
Servo doorServo;
#define SERVO_PIN    32
#define DOOR_OPEN    90
#define DOOR_CLOSED   0

// ── Keypad ────────────────────────────────────────────
const byte ROWS = 4, COLS = 4;
char keys[ROWS][COLS] = {
  {'1','2','3','A'},
  {'4','5','6','B'},
  {'7','8','9','C'},
  {'*','0','#','D'}
};
byte rowPins[ROWS] = {23, 19, 18, 17};
byte colPins[COLS] = {33,  4, 15, 27};
Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

// ── Ultrasonic ────────────────────────────────────────
#define TRIG_PIN    13
#define ECHO_PIN    14
#define PRESENCE_CM 20

// ── Buzzer ────────────────────────────────────────────
#define BUZZER_PIN 16

// ── RGB LED (common anode → LOW = ON) ─────────────────
#define LED_R 2
#define LED_G 25
#define LED_B 26

// ── Relay ─────────────────────────────────────────────
#define RELAY_PIN 5

// ── Gas sensor MQ-2 ───────────────────────────────────
#define GAS_AOUT          34
#define GAS_DOUT          35
#define GAS_THRESHOLD   3800
#define SMOKE_CONFIRM_COUNT 5

// ── Κωδικός ───────────────────────────────────────────
const String CORRECT_PIN = "1234";
String inputBuffer = "";

// ── State ─────────────────────────────────────────────
bool doorOpen    = false;
bool smokeAlert  = false;
bool alarmActive = false;
int  smokeCounter = 0;

// ─────────────────────────────────────────────────────
void setRGB(bool r, bool g, bool b) {
  digitalWrite(LED_R, !r);
  digitalWrite(LED_G, !g);
  digitalWrite(LED_B, !b);
}

long readDistanceCM() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);
  long duration = pulseIn(ECHO_PIN, HIGH, 30000);
  return duration / 58;
}

void openDoor() {
  doorServo.write(DOOR_OPEN);
  doorOpen = true;
  digitalWrite(RELAY_PIN, HIGH);
}

void closeDoor() {
  if (smokeAlert) return;
  doorServo.write(DOOR_CLOSED);
  doorOpen = false;
  digitalWrite(RELAY_PIN, LOW);
}

void triggerAlarm() {
  tone(BUZZER_PIN, 1000, 500);
  setRGB(true, false, false);
}

void smokeAlertMode() {
  smokeAlert  = true;
  alarmActive = true;
  openDoor();
  lcd.clear();
  lcd.setCursor(0, 0); lcd.print("!! SMOKE ALERT !!");
  lcd.setCursor(0, 1); lcd.print("Door forced OPEN");
  triggerAlarm();
  Blynk.virtualWrite(V1, 1);
  Blynk.logEvent("smoke_alert", "Smoke detected! Door forced open.");
}

void clearSmokeAlert() {
  smokeAlert   = false;
  alarmActive  = false;
  smokeCounter = 0;
  noTone(BUZZER_PIN);
  lcd.clear();
  lcd.setCursor(0, 0); lcd.print("Enter PIN:");
  setRGB(false, true, false);
  Blynk.virtualWrite(V1, 0);
}

// ─────────────────────────────────────────────────────
void setup() {
  Serial.begin(115200);

  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);

  lcd.init();
  lcd.backlight();
  lcd.setCursor(0, 0); lcd.print("Smart Door v1.0");
  lcd.setCursor(0, 1); lcd.print("Initializing...");

  doorServo.attach(SERVO_PIN);
  closeDoor();

  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);
  pinMode(BUZZER_PIN, OUTPUT);
  pinMode(LED_R, OUTPUT);
  pinMode(LED_G, OUTPUT);
  pinMode(LED_B, OUTPUT);
  pinMode(RELAY_PIN, OUTPUT);
  pinMode(GAS_DOUT, INPUT);

  digitalWrite(RELAY_PIN, LOW);
  setRGB(false, true, false);

  delay(1500);
  lcd.clear();
  lcd.setCursor(0, 0); lcd.print("Enter PIN:");
}

// ─────────────────────────────────────────────────────
void loop() {
  Blynk.run();

  // ── 1. MQ-2 έλεγχος με debounce ──────────────────
  int  gasLevel = analogRead(GAS_AOUT);
  bool digitalSmoke = false;   // αγνοούμε το DOUT

  Blynk.virtualWrite(V0, gasLevel);
  Serial.printf("Gas: %d | Counter: %d\n", gasLevel, smokeCounter);

  if (gasLevel > GAS_THRESHOLD) {
    smokeCounter++;
  } else {
    smokeCounter = 0;
  }

  if (smokeCounter >= SMOKE_CONFIRM_COUNT && !smokeAlert) {
    smokeAlertMode();
  }

  if (smokeAlert && gasLevel < GAS_THRESHOLD) {
    clearSmokeAlert();
  }

  // Κατά τη διάρκεια smoke alert: μόνο blink και έξοδος
  if (smokeAlert) {
    static unsigned long lastBeep = 0;
    if (millis() - lastBeep > 500) {
      lastBeep = millis();
      alarmActive = !alarmActive;
      if (alarmActive) triggerAlarm();
      else { noTone(BUZZER_PIN); setRGB(true, false, false); }
    }
    return;
  }

  // ── 2. Ultrasonic ─────────────────────────────────
  long dist    = readDistanceCM();
  bool presence = (dist > 0 && dist < PRESENCE_CM);

  if (presence && !doorOpen) {
    lcd.clear();
    lcd.setCursor(0, 0); lcd.print("Person detected!");
    lcd.setCursor(0, 1); lcd.print("Enter PIN:");
    setRGB(false, false, true);
  }

  // ── 3. Keypad ─────────────────────────────────────
  char key = keypad.getKey();
  if (key) {
    if (key == '#') {
      if (inputBuffer == CORRECT_PIN) {
        lcd.clear();
        lcd.setCursor(0, 0); lcd.print("Access Granted");
        setRGB(false, true, false);
        tone(BUZZER_PIN, 2000, 200);
        openDoor();
        delay(5000);
        closeDoor();
        lcd.clear();
        lcd.setCursor(0, 0); lcd.print("Enter PIN:");
        setRGB(false, true, false);
      } else {
        lcd.clear();
        lcd.setCursor(0, 0); lcd.print("Wrong PIN!");
        setRGB(true, false, false);
        tone(BUZZER_PIN, 300, 1000);
        delay(2000);
        lcd.clear();
        lcd.setCursor(0, 0); lcd.print("Enter PIN:");
        setRGB(false, true, false);
      }
      inputBuffer = "";
      lcd.setCursor(0, 1); lcd.print("                ");

    } else if (key == '*') {
      inputBuffer = "";
      lcd.setCursor(0, 1); lcd.print("                ");

    } else {
      if (inputBuffer.length() < 4) {
        inputBuffer += key;
        lcd.setCursor(0, 1);
        for (unsigned int i = 0; i < inputBuffer.length(); i++) lcd.print('*');
      }
    }
  }

  delay(50);
}
